<!-- ═══════════════════════════════════════════════════
     NOTICIAS — CARRUSEL
════════════════════════════════════════════════════ -->
<section style="padding:80px 0 80px;background:#fff;overflow:hidden;">
  <div style="max-width:1200px;margin:0 auto;padding:0 24px;">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:40px;flex-wrap:wrap;gap:16px;">
      <div>
        <div class="section-label">Del Barrio</div>
        <h2 class="section-title">Últimas <span style="color:#8B0000;">Noticias</span></h2>
      </div>
      <div style="display:flex;gap:8px;align-items:center;">
        <button onclick="slideNews(-1)" id="btn-prev"
          style="width:44px;height:44px;border:1.5px solid #E4E4E7;border-radius:50%;background:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s;color:#0A0A0A;box-shadow:0 2px 8px rgba(0,0,0,0.06);"
          onmouseover="this.style.borderColor='#8B0000';this.style.color='#8B0000'" onmouseout="this.style.borderColor='#E4E4E7';this.style.color='#0A0A0A'">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button onclick="slideNews(1)" id="btn-next"
          style="width:44px;height:44px;border:1.5px solid #E4E4E7;border-radius:50%;background:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s;color:#0A0A0A;box-shadow:0 2px 8px rgba(0,0,0,0.06);"
          onmouseover="this.style.borderColor='#8B0000';this.style.color='#8B0000'" onmouseout="this.style.borderColor='#E4E4E7';this.style.color='#0A0A0A'">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
        <a href="/noticias" class="btn btn-primary" style="font-size:12px;padding:10px 20px;">Ver todas →</a>
      </div>
    </div>
  </div>

  <!-- Carrusel track -->
  <div style="position:relative;overflow:hidden;">
    <div id="news-track" style="display:flex;gap:24px;transition:transform 0.5s cubic-bezier(0.4,0,0.2,1);will-change:transform;padding:0 24px 8px;max-width:none;">
      <%
      // Triple set: [copy A] + [originals] + [copy B]
      // JS starts at index N (the originals), corrects silently when hitting either end
      var newsTriple = news.concat(news).concat(news);
      newsTriple.forEach(function(n, i){ %>
      <a href="/noticias/<%= n.slug %>"
         style="text-decoration:none;flex-shrink:0;width:340px;border-radius:16px;overflow:hidden;background:#fff;display:flex;flex-direction:column;transition:box-shadow 0.3s,transform 0.3s;box-shadow:0 2px 12px rgba(0,0,0,0.06);"
         onmouseover="this.style.boxShadow='0 12px 40px rgba(0,0,0,0.12)';this.style.transform='translateY(-4px)'"
         onmouseout="this.style.boxShadow='0 2px 12px rgba(0,0,0,0.06)';this.style.transform='translateY(0)'">
        <div style="position:relative;height:220px;overflow:hidden;flex-shrink:0;">
          <img src="<%= n.thumbnail || n.image %>" alt="<%= n.title %>"
               style="width:100%;height:100%;object-fit:cover;transition:transform 0.6s;" />
          <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(7,20,36,0.75) 0%,rgba(7,20,36,0.1) 55%,transparent 100%);"></div>
          <div style="position:absolute;top:14px;left:14px;">
            <span style="display:inline-flex;align-items:center;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;background:rgba(139,0,0,0.9);color:#fff;padding:4px 10px;border-radius:4px;backdrop-filter:blur(4px);"><%= n.category %></span>
          </div>
          <div style="position:absolute;bottom:0;left:0;right:0;padding:16px 18px;">
            <h3 style="font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:0.03em;text-transform:uppercase;color:#fff;line-height:1.05;text-shadow:0 1px 4px rgba(0,0,0,0.4);"><%= n.title %></h3>
          </div>
        </div>
        <div style="padding:18px 20px 20px;flex:1;display:flex;flex-direction:column;justify-content:space-between;gap:12px;">
          <p style="font-family:'Inter',sans-serif;font-size:13px;color:#52525B;line-height:1.6;"><%= n.subtitle %></p>
          <div style="display:flex;align-items:center;justify-content:space-between;">
            <div style="display:flex;align-items:center;gap:6px;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="#A1A1AA"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11zM7 11h5v5H7z"/></svg>
              <span style="font-family:'Inter',sans-serif;font-size:11px;color:#A1A1AA;">
                <%= new Date(n.date).toLocaleDateString('es-AR',{day:'2-digit',month:'short',year:'numeric'}) %>
              </span>
            </div>
            <span style="display:inline-flex;align-items:center;gap:4px;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:12px;letter-spacing:0.06em;text-transform:uppercase;color:#8B0000;">
              Leer
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
  </div>

  <!-- Dots (solo los originales) -->
  <div style="display:flex;justify-content:center;gap:6px;margin-top:28px;" id="news-dots">
    <% news.forEach(function(n, i){ %>
    <button onclick="goToSlide(<%= i %>)" id="dot-<%= i %>"
      style="width:<%= i===0?'28px':'8px' %>;height:8px;border-radius:99px;border:none;background:<%= i===0?'#8B0000':'#D4D4D8' %>;cursor:pointer;transition:all 0.3s;padding:0;"></button>
    <% }) %>
  </div>
</section>

<script>
const newsTotal = <%= news.length %>;
const cardWidth = 364; // card 340px + gap 24px
let newsIdx = newsTotal; // start at beginning of middle (original) set

function updateCarousel(animated) {
  const track = document.getElementById('news-track');
  if (!track) return;
  track.style.transition = animated ? 'transform 0.5s cubic-bezier(0.4,0,0.2,1)' : 'none';
  track.style.transform = `translateX(-${newsIdx * cardWidth}px)`;
  const dotIdx = newsIdx % newsTotal;
  for (let i = 0; i < newsTotal; i++) {
    const d = document.getElementById('dot-' + i);
    if (d) { d.style.background = i === dotIdx ? '#8B0000' : '#D4D4D8'; d.style.width = i === dotIdx ? '28px' : '8px'; }
  }
}

// After each animated move, silently reposition into the middle set if needed
function correctLoop() {
  if (newsIdx >= newsTotal * 2) { newsIdx -= newsTotal; updateCarousel(false); }
  else if (newsIdx < newsTotal) { newsIdx += newsTotal; updateCarousel(false); }
}

function slideNews(dir) {
  newsIdx += dir;
  updateCarousel(true);
  setTimeout(correctLoop, 520);
}

function goToSlide(i) {
  newsIdx = newsTotal + i;
  updateCarousel(true);
}

// Set initial position without animation
updateCarousel(false);

setInterval(() => slideNews(1), 5000);
</script>

