          </div>
          <div style="text-align:center;">
            <div style="font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:0.05em;color:#fff;text-transform:uppercase;">@slvcoficial</div>
            <div style="font-family:'Inter',sans-serif;font-size:12px;color:rgba(255,255,255,0.6);margin-top:3px;">Canal oficial · YouTube</div>
          </div>
        </div>
      </a>

    </div>
  </div>
</section>
<% } %>

<!-- ═══════════════════════════════════════════════════
     FIXTURE + TABLA (side by side)
════════════════════════════════════════════════════ -->
<section style="padding:80px 24px;background:#F4F4F5;" id="fixture">
  <div style="max-width:1200px;margin:0 auto;">
    <!-- Header strip -->
    <div style="background:#fff;border-bottom:1px solid #E4E4E7;padding:20px 0 0;margin-bottom:0;border-radius:16px 16px 0 0;overflow:hidden;">
      <div style="padding:0 24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
        <div>
          <div class="section-label" style="margin-bottom:4px;">Primera "A" · Rueda 1</div>
          <h2 class="section-title" style="font-size:clamp(22px,3vw,32px);">Fixture & Tabla</h2>
        </div>
        <!-- Fecha selector -->
        <div style="display:flex;gap:4px;background:#fff;border-radius:8px;padding:4px;">
          <% [12,13,14,15].forEach(function(f){ %>
          <button class="tab-btn <%= f===13 ? 'active' : '' %>" onclick="showFecha(<%= f %>)" id="tab-<%= f %>">
            F<%= f %>
          </button>
          <% }) %>
        </div>
      </div>
      <!-- Tabs fixture / tabla -->
      <div style="display:flex;gap:0;margin-top:16px;border-top:1px solid #E4E4E7;">
        <button class="fixture-tab-btn active" id="ftab-fixture" onclick="switchSection('fixture')"
          style="flex:1;padding:12px;font-family:'Nexa',sans-serif;font-weight:700;font-size:11px;letter-spacing:0.08em;text-transform:uppercase;border:none;background:#fff;cursor:pointer;border-bottom:2px solid #8B0000;color:#8B0000;transition:all 0.2s;">
          Fixture
        </button>
        <button class="fixture-tab-btn" id="ftab-tabla" onclick="switchSection('tabla')"
          style="flex:1;padding:12px;font-family:'Nexa',sans-serif;font-weight:700;font-size:11px;letter-spacing:0.08em;text-transform:uppercase;border:none;background:#fff;cursor:pointer;border-bottom:2px solid transparent;color:#71717A;transition:all 0.2s;" id="tabla">
          Tabla de Posiciones
        </button>
      </div>
    </div>

    <!-- FIXTURE panel -->
    <div id="panel-fixture" style="background:#fff;border-radius:0 0 16px 16px;border:1px solid #E4E4E7;border-top:none;">
      <% [12,13,14,15].forEach(function(f){ %>
      <div id="fecha-<%= f %>" style="display:<%= f===13 ? 'block' : 'none' %>;">
        <% const fechaMatches = fixture.filter(m => m.fecha === f); %>
        <% fechaMatches.forEach(function(m, i){ %>
        <%
          const tL = teams[m.local]    || {};
          const tV = teams[m.visitante] || {};
          const isSlvc = m.local === 'SAN LORENZO V.C.' || m.visitante === 'SAN LORENZO V.C.';
        %>
        <div style="display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:12px;padding:16px 24px;border-bottom:<%= i < fechaMatches.length-1 ? '1px solid #F4F4F5' : 'none' %>;background:<%= isSlvc ? 'rgba(139,0,0,0.02)' : 'transparent' %>;transition:background 0.15s;"
             onmouseover="this.style.background='<%= isSlvc ? 'rgba(139,0,0,0.05)' : '#FAFAFA' %>'"
             onmouseout="this.style.background='<%= isSlvc ? 'rgba(139,0,0,0.02)' : 'transparent' %>'">
          <!-- Local -->
          <div style="display:flex;align-items:center;justify-content:flex-end;gap:10px;text-align:right;">
            <span class="font-nexa-bold" style="font-size:13px;color:#0A0A0A;text-transform:uppercase;line-height:1.2;<%= m.local === 'SAN LORENZO V.C.' ? 'color:#8B0000;' : '' %>"><%= m.local %></span>
            <img src="<%= m.local === 'SAN LORENZO V.C.' ? '/images/Logo.1268415243901683eac4.png' : (tL.logo || '') %>" alt="" style="width:30px;height:30px;object-fit:contain;flex-shrink:0;" onerror="this.style.display='none'" />
          </div>
          <!-- Score / vs -->
          <div style="text-align:center;min-width:80px;">
            <% if (m.jugado) { %>
              <div class="font-zing" style="font-size:22px;color:#0A0A0A;line-height:1;"><%= m.golL %> – <%= m.golV %></div>
              <div class="badge badge-done" style="margin-top:4px;font-size:9px;">Final</div>
            <% } else { %>
              <div class="font-zing" style="font-size:18px;color:#D4D4D8;line-height:1;">vs</div>
              <div class="badge badge-bordo" style="margin-top:4px;font-size:9px;">Pendiente</div>
            <% } %>
          </div>
          <!-- Visitante -->
          <div style="display:flex;align-items:center;justify-content:flex-start;gap:10px;">
            <img src="<%= m.visitante === 'SAN LORENZO V.C.' ? '/images/Logo.1268415243901683eac4.png' : (tV.logo || '') %>" alt="" style="width:30px;height:30px;object-fit:contain;flex-shrink:0;" onerror="this.style.display='none'" />
            <span class="font-nexa-bold" style="font-size:13px;color:#0A0A0A;text-transform:uppercase;line-height:1.2;<%= m.visitante === 'SAN LORENZO V.C.' ? 'color:#8B0000;' : '' %>"><%= m.visitante %></span>
          </div>
        </div>
        <% }) %>
      </div>
      <% }) %>
    </div>

    <!-- TABLA panel -->
    <div id="panel-tabla" style="display:none;background:#fff;border-radius:0 0 16px 16px;border:1px solid #E4E4E7;border-top:none;overflow:hidden;" id="tabla">
      <table class="standings-table">
        <thead>
          <tr>
            <th style="width:36px;">#</th>
            <th style="text-align:left;padding-left:8px;">Equipo</th>
            <th>PJ</th><th>PG</th><th>PE</th><th>PP</th>
            <th>GF</th><th>GC</th><th>Dif</th>
            <th style="color:#8B0000;">PTS</th>
          </tr>
        </thead>
        <tbody>
          <% tabla.forEach(function(e){ %>
          <%
            const isUs = e.equipo === 'SAN LORENZO V.C.';
            const diff = e.gf - e.gc;
            const tInfo = teams[e.equipo] || {};
          %>
          <tr class="<%= isUs ? 'slvc-row' : '' %>">
            <td>
              <div style="display:flex;align-items:center;justify-content:center;">
                <% if(e.pos<=3){ %>
                  <span class="font-nexa-bold" style="font-size:12px;color:<%= e.pos===1?'#C8922A':e.pos===2?'#A0A0A0':'#CD7F32' %>;"><%= e.pos %></span>
                <% } else { %>
                  <span class="font-nexa" style="font-size:12px;color:#A1A1AA;"><%= e.pos %></span>
                <% } %>
              </div>
            </td>
            <td style="text-align:left;padding-left:8px;">
              <div style="display:flex;align-items:center;gap:10px;">
                <img src="<%= tInfo.logo || '' %>" alt="" style="width:24px;height:24px;object-fit:contain;flex-shrink:0;" onerror="this.style.display='none'" />
                <span class="<%= isUs ? 'font-nexa-bold' : 'font-nexa' %>" style="font-size:13px;text-transform:uppercase;<%= isUs ? 'color:#8B0000;' : 'color:#0A0A0A;' %>">
                  <%= e.equipo %>
                </span>
                <% if(isUs){ %><span class="badge badge-bordo" style="font-size:8px;padding:2px 6px;">Nosotros</span><% } %>
              </div>
            </td>
            <td class="font-nexa" style="font-size:13px;color:#71717A;"><%= e.pj %></td>
            <td class="font-nexa-bold" style="font-size:13px;color:#16a34a;"><%= e.pg %></td>
            <td class="font-nexa" style="font-size:13px;color:#71717A;"><%= e.pe %></td>
            <td class="font-nexa" style="font-size:13px;color:#dc2626;"><%= e.pp %></td>
            <td class="font-nexa" style="font-size:13px;color:#71717A;"><%= e.gf %></td>
            <td class="font-nexa" style="font-size:13px;color:#71717A;"><%= e.gc %></td>
            <td class="font-nexa" style="font-size:13px;color:<%= diff>0?'#16a34a':diff<0?'#dc2626':'#71717A' %>;">
              <%= diff > 0 ? '+'+diff : diff %>
            </td>
            <td class="font-nexa-bold" style="font-size:15px;color:<%= isUs ? '#8B0000' : '#0A0A0A' %>;"><%= e.pts %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <!-- LAPF link -->
      <div style="padding:14px 20px;border-top:1px solid #E4E4E7;background:#F4F4F5;display:flex;align-items:center;justify-content:space-between;">
        <span class="font-nexa" style="font-size:11px;color:#A1A1AA;">Fuente: Liga Amateur Platense · Actualizado desde lapf.com.ar</span>
        <a href="https://www.lapf.com.ar/datos-torneo/165/442/12/1" target="_blank" class="font-nexa-bold"
           style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:#8B0000;text-decoration:none;">Ver en LAPF →</a>
      </div>
    </div>
  </div>
</section>

<script>
function showFecha(n) {
  [12,13,14,15].forEach(f => {
    const el = document.getElementById('fecha-'+f);
    const btn = document.getElementById('tab-'+f);
    if(el) el.style.display = f===n ? 'block' : 'none';
    if(btn) {
      btn.classList.toggle('active', f===n);
    }
  });
}
function switchSection(s) {
  const fp = document.getElementById('panel-fixture');
  const tp = document.getElementById('panel-tabla');
  const fb = document.getElementById('ftab-fixture');
  const tb = document.getElementById('ftab-tabla');
  fp.style.display = s==='fixture' ? 'block' : 'none';
  tp.style.display = s==='tabla'   ? 'block' : 'none';
  fb.style.borderBottomColor = s==='fixture' ? '#8B0000' : 'transparent';
  fb.style.color = s==='fixture' ? '#8B0000' : '#71717A';
  tb.style.borderBottomColor = s==='tabla' ? '#8B0000' : 'transparent';
  tb.style.color = s==='tabla' ? '#8B0000' : '#71717A';
}
</script>

