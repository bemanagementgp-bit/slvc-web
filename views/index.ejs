<%- include('partials/head', { title: '' }) %>
<%- include('partials/sound-gate') %>
<%- include('partials/nav') %>

<style>
/* ── Responsive 2-col grids ── */
.r-grid-2 { display:grid; grid-template-columns:1fr; gap:48px; align-items:start; }
@media(min-width:900px){
  .r-grid-2 { grid-template-columns:1fr 1fr; align-items:center; }
}
/* timeline hide scrollbar */
#timeline-scroll::-webkit-scrollbar { display:none; }
/* Hero mobile: video completo sin espacio vacío */
@media(max-width:768px){
  #hero {
    height: auto !important;
    min-height: 0 !important;
  }
  #hero-video {
    position: relative !important;
    width: 100% !important;
    height: auto !important;
    object-fit: unset !important;
  }
  #hero-poster {
    position: absolute !important;
    inset: 0 !important;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
  }
  #hero-play-btn, #hero-sound-btn {
    width: 36px !important;
    height: 36px !important;
  }
}
</style>

<!-- ═══════════════════════════════════════════════════
     HERO
════════════════════════════════════════════════════ -->
<section id="hero" style="position:relative;width:100%;height:100svh;min-height:600px;overflow:hidden;background:#0A0A0A;">
  <!-- Video -->
  <video id="hero-video" muted playsinline
         poster="/images/new1.c91ede4c59d431d30c08.jpg"
         style="width:100%;height:100%;object-fit:cover;display:block;transition:opacity 1s;">
    <source src="/video/hero.mp4" type="video/mp4" />
  </video>
  <!-- Top gradient: opaque at nav height, fades out below -->
  <div style="position:absolute;top:0;left:0;right:0;height:160px;background:linear-gradient(to bottom,rgba(0,0,0,0.88) 0%,rgba(0,0,0,0.88) 64px,rgba(0,0,0,0.2) 110px,transparent 100%);z-index:1;pointer-events:none;"></div>
  <!-- Poster fallback (shown when video ends) -->
  <img id="hero-poster"
       src="/images/hero-poster.png"
       alt=""
       style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 30%;opacity:0;transition:opacity 1.2s;pointer-events:none;" />
  <!-- Play/Pause + Sound controls -->
  <div style="position:absolute;bottom:28px;right:28px;display:flex;gap:10px;z-index:10;">
    <!-- Play/Pause -->
    <button id="hero-play-btn" onclick="toggleHeroPlay()"
      style="width:44px;height:44px;border-radius:50%;background:rgba(0,0,0,0.55);border:1.5px solid rgba(255,255,255,0.25);backdrop-filter:blur(8px);cursor:pointer;display:flex;align-items:center;justify-content:center;color:#fff;transition:all 0.2s;"
      title="Pausar / Reproducir">
      <svg id="icon-pause" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
      <svg id="icon-play"  width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="display:none;"><path d="M8 5v14l11-7z"/></svg>
    </button>
    <!-- Sound -->
    <button id="hero-sound-btn" onclick="toggleHeroSound()"
      style="width:44px;height:44px;border-radius:50%;background:rgba(0,0,0,0.55);border:1.5px solid rgba(255,255,255,0.25);backdrop-filter:blur(8px);cursor:pointer;display:flex;align-items:center;justify-content:center;color:#fff;transition:all 0.2s;"
      title="Activar / Silenciar">
      <svg id="icon-muted"   width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>
      <svg id="icon-sound"  width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="display:none;"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>
    </button>
  </div>
</section>

<script>
(function(){
  const video = document.getElementById('hero-video');
  const poster = document.getElementById('hero-poster');

  if(!video) return;

  video.addEventListener('ended', function(){
    video.style.opacity = '0';
    poster.style.opacity = '1';
    // hide play button since video is done
    const pb = document.getElementById('hero-play-btn');
    if(pb) pb.style.display = 'none';
  });
})();

function toggleHeroPlay() {
  const video = document.getElementById('hero-video');
  const ip = document.getElementById('icon-pause');
  const ipl = document.getElementById('icon-play');
  if(!video) return;
  if(video.paused) {
    video.play();
    ip.style.display = ''; ipl.style.display = 'none';
  } else {
    video.pause();
    ip.style.display = 'none'; ipl.style.display = '';
  }
}

function toggleHeroSound() {
  const video = document.getElementById('hero-video');
  const im = document.getElementById('icon-muted');
  const is = document.getElementById('icon-sound');
  if(!video) return;
  video.muted = !video.muted;
  im.style.display = video.muted ? '' : 'none';
  is.style.display = video.muted ? 'none' : '';
}
</script>

<!-- ═══════════════════════════════════════════════════
     NEWS TICKER
════════════════════════════════════════════════════ -->
<div style="background:#8B0000;padding:0;overflow:hidden;border-bottom:1px solid rgba(0,0,0,0.1);">
  <div style="display:flex;align-items:stretch;">
    <div style="background:#5C0000;padding:0 20px;display:flex;align-items:center;gap:8px;white-space:nowrap;flex-shrink:0;">
      <span style="width:7px;height:7px;background:#C8922A;border-radius:99px;display:inline-block;"></span>
      <span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:#fff;">Últimas</span>
    </div>
    <div id="news-ticker" style="flex:1;padding:11px 0;">
      <div class="ticker-inner">
        <% news.forEach(function(n){ %>
          <a href="/noticias/<%= n.slug %>" style="font-family:'Inter',sans-serif;font-size:12px;color:rgba(255,255,255,0.85);text-decoration:none;padding:0 40px;white-space:nowrap;transition:color 0.2s;"
             onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.85)'">
            <strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;color:#C8922A;margin-right:6px;letter-spacing:0.06em;"><%= n.category %> ·</strong>
            <%= n.title %>
          </a>
        <% }) %>
        <% news.forEach(function(n){ %>
          <a href="/noticias/<%= n.slug %>" style="font-family:'Inter',sans-serif;font-size:12px;color:rgba(255,255,255,0.85);text-decoration:none;padding:0 40px;white-space:nowrap;">
            <strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;color:#C8922A;margin-right:6px;"><%= n.category %> ·</strong>
            <%= n.title %>
          </a>
        <% }) %>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════
     HISTORIA — LÍNEA DE TIEMPO
════════════════════════════════════════════════════ -->
<section id="historia" style="padding:72px 0 64px;overflow:hidden;position:relative;background:#060D18;">
  <!-- Mesh gradient background -->
  <div style="position:absolute;inset:0;background:
    radial-gradient(ellipse 55% 70% at 15% 60%, rgba(92,0,0,0.22) 0%, transparent 65%),
    radial-gradient(ellipse 45% 60% at 85% 40%, rgba(200,146,42,0.07) 0%, transparent 65%),
    radial-gradient(ellipse 80% 50% at 50% 100%, rgba(7,20,36,0.9) 0%, transparent 100%);
    pointer-events:none;z-index:0;"></div>
  <!-- Dot grid overlay -->
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,0.028) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>
  <!-- Top fade -->
  <div style="position:absolute;top:0;left:0;right:0;height:80px;background:linear-gradient(to bottom,#060D18,transparent);pointer-events:none;z-index:0;"></div>

  <div style="position:relative;z-index:1;max-width:1200px;margin:0 auto;padding:0 24px 40px;">
    <div class="section-label" style="color:rgba(255,255,255,0.4);">Desde 1990</div>
    <h2 class="section-title" style="color:#fff;">Historia del <span style="color:#C8922A;">Cuervo</span></h2>
  </div>

  <!-- Timeline horizontal -->
  <div id="timeline-scroll" style="position:relative;z-index:1;overflow-x:auto;overflow-y:hidden;padding:0 24px 32px;cursor:grab;user-select:none;scrollbar-width:none;-ms-overflow-style:none;">
    <div id="timeline-inner" style="display:inline-flex;align-items:flex-start;gap:0;position:relative;padding-bottom:8px;">

      <!-- Connecting line — glowing gradient -->
      <div style="position:absolute;top:20px;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,rgba(92,0,0,0.6) 5%,#8B0000 25%,#C8922A 55%,#8B0000 80%,transparent 100%);pointer-events:none;"></div>
      <div style="position:absolute;top:19px;left:0;right:0;height:3px;background:linear-gradient(to right,transparent,rgba(139,0,0,0.15) 5%,rgba(139,0,0,0.25) 30%,rgba(200,146,42,0.3) 55%,rgba(139,0,0,0.2) 80%,transparent 100%);filter:blur(3px);pointer-events:none;"></div>

      <%
      var hitos = [
        { year:'1990', fa:'fa-solid fa-flag',        color:'#C8922A', borderColor:'rgba(200,146,42,0.4)', title:'Fundación', text:'Nino Menechela y Alfredo Giommi sueñan con un club propio y fundan San Lorenzo de Villa Castells.' },
        { year:'2003', fa:'fa-solid fa-ban',          color:'#ef4444', borderColor:'rgba(239,68,68,0.4)',  title:'El desalojo', text:'El club es desalojado de sus tierras. Años de lucha y vida nómade por el barrio.' },
        { year:'2008', fa:'fa-solid fa-location-dot', color:'#9B1020', borderColor:'rgba(155,16,32,0.4)',  title:'Nuevo predio', text:'Se consigue terreno en 9 y 505. El Cuervo vuelve a tener suelo donde plantar banderas.' },
        { year:'2013', fa:'fa-solid fa-house',        color:'#C8922A', borderColor:'rgba(200,146,42,0.4)', title:'Casa propia', text:'El barrio recibe al club en 7 y 485. El Nido queda plantado para siempre.' },
        { year:'2014', fa:'fa-solid fa-arrow-up',     color:'#22c55e', borderColor:'rgba(34,197,94,0.4)',  title:'Ascenso a 1ª A', text:'El Cuervo sube a Primera "A" de la Liga Amateur Platense. Un sueño hecho realidad.' },
        { year:'2019', fa:'fa-solid fa-trophy',       color:'#C8922A', borderColor:'rgba(200,146,42,0.5)', title:'Campeones LAPF', text:'San Lorenzo de Villa Castells se corona campeón de la Liga Amateur Platense Primera "A".' },
        { year:'2024', fa:'fa-solid fa-trophy',       color:'#C8922A', borderColor:'rgba(200,146,42,0.5)', title:'Doble corona', text:'Campeones de la Liga y del Torneo Clasificatorio al Regional. 4ta estrella.' },
        { year:'2026', fa:'fa-solid fa-star',         color:'#C8922A', borderColor:'rgba(200,146,42,0.6)', title:'5ta Estrella', text:'Campeones del Torneo Clasificatorio al Regional. El logro más grande de la historia.' },
        { year:'Hoy',  fa:'fa-solid fa-fire',         color:'#9B1020', borderColor:'rgba(155,16,32,0.4)',  title:'Seguimos creciendo', text:'En 7 y 485, nuevas generaciones comparten el sueño de Alfredo y Nino.' }
      ];
      %>

      <% hitos.forEach(function(h, i){ %>
      <div style="display:flex;flex-direction:column;align-items:center;width:300px;flex-shrink:0;padding:0 30px;position:relative;">
        <!-- Icon circle with glow -->
        <div style="position:relative;margin-bottom:24px;">
          <div style="position:absolute;inset:-6px;border-radius:50%;background:<%= h.color %>;opacity:0.12;filter:blur(8px);pointer-events:none;"></div>
          <div style="width:52px;height:52px;border-radius:50%;background:rgba(6,13,24,0.95);border:1.5px solid <%= h.borderColor %>;display:flex;align-items:center;justify-content:center;z-index:2;flex-shrink:0;box-shadow:0 0 0 4px rgba(6,13,24,0.9),0 0 20px rgba(0,0,0,0.6);position:relative;transition:transform 0.25s,border-color 0.25s;"
               onmouseover="this.style.transform='scale(1.18)';this.style.borderColor='<%= h.color %>'" onmouseout="this.style.transform='scale(1)';this.style.borderColor='<%= h.borderColor %>'">
            <i class="<%= h.fa %>" style="color:<%= h.color %>;font-size:18px;"></i>
          </div>
        </div>
        <!-- Card body -->
        <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:4px;padding:20px 18px;text-align:center;backdrop-filter:blur(8px);transition:background 0.25s,border-color 0.25s;"
             onmouseover="this.style.background='rgba(255,255,255,0.065)';this.style.borderColor='rgba(255,255,255,0.12)'" onmouseout="this.style.background='rgba(255,255,255,0.03)';this.style.borderColor='rgba(255,255,255,0.06)'">
          <!-- Year -->
          <div style="font-family:'Bebas Neue',sans-serif;font-size:38px;letter-spacing:0.04em;color:<%= h.color %>;line-height:1;margin-bottom:6px;"><%= h.year %></div>
          <!-- Title -->
          <div style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:13px;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.9);margin-bottom:10px;"><%= h.title %></div>
          <!-- Divider -->
          <div style="height:1px;background:linear-gradient(to right,transparent,<%= h.borderColor %>,transparent);margin-bottom:10px;"></div>
          <!-- Text -->
          <div style="font-family:'Inter',sans-serif;font-size:12px;color:rgba(255,255,255,0.42);line-height:1.65;"><%= h.text %></div>
        </div>
      </div>
      <% if(i < hitos.length-1){ %>
      <div style="width:8px;flex-shrink:0;"></div>
      <% } %>
      <% }) %>
    </div>
  </div>

  <!-- Drag hint -->
  <div style="position:relative;z-index:1;text-align:center;margin-top:4px;">
    <span style="font-family:'Inter',sans-serif;font-size:11px;color:rgba(255,255,255,0.25);letter-spacing:0.1em;text-transform:uppercase;">← deslizá para ver más →</span>
  </div>
</section>

<script>
(function(){
  const el = document.getElementById('timeline-scroll');
  if(!el) return;
  let down=false, startX=0, scrollL=0;
  el.addEventListener('mousedown', e=>{ down=true; startX=e.pageX-el.offsetLeft; scrollL=el.scrollLeft; el.style.cursor='grabbing'; });
  el.addEventListener('mouseleave',()=>{ down=false; el.style.cursor='grab'; });
  el.addEventListener('mouseup',  ()=>{ down=false; el.style.cursor='grab'; });
  el.addEventListener('mousemove',e=>{ if(!down) return; e.preventDefault(); el.scrollLeft=scrollL-(e.pageX-el.offsetLeft-startX); });
})();
</script>

