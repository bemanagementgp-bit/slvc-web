<script>
function sendWhatsApp(e) {
  e.preventDefault();
  const nombre  = document.getElementById('cf-nombre').value.trim();
  const tel     = document.getElementById('cf-tel').value.trim();
  const asunto  = document.getElementById('cf-asunto').value;
  const msg     = document.getElementById('cf-msg').value.trim();
  const text = encodeURIComponent(
    `Hola! Soy ${nombre}${tel?' ('+tel+')':''}.\nAsunto: ${asunto}\n${msg}`
  );
  window.open(`https://wa.me/5492211234567?text=${text}`, '_blank');
}
</script>

