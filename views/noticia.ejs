<%- include('partials/head', { title: noticia.title }) %>
<%- include('partials/nav') %>

<!-- Hero -->
<div style="position:relative;height:60vh;min-height:420px;overflow:hidden;background:#0A0A0A;">
  <img src="<%= noticia.image %>" alt="<%= noticia.title %>"
       style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.45;" />
  <div style="position:absolute;inset:0;background:linear-gradient(to top,#fff 0%,rgba(10,10,10,0.6) 50%,rgba(10,10,10,0.3) 100%);"></div>
  <div style="position:absolute;bottom:0;left:0;right:0;padding:48px 24px;">
    <div style="max-width:800px;margin:0 auto;">
      <a href="/noticias" style="display:inline-flex;align-items:center;gap:6px;font-family:'Nexa',sans-serif;font-weight:300;font-size:12px;color:rgba(255,255,255,0.5);text-decoration:none;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:16px;transition:color 0.2s;"
         onmouseover="this.style.color='rgba(255,255,255,0.9)'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">
        ← Noticias
      </a>
      <span class="badge badge-bordo" style="background:rgba(139,0,0,0.7);color:#C8922A;margin-bottom:12px;"><%= noticia.category %></span>
      <h1 class="font-zing" style="font-size:clamp(30px,5vw,60px);color:#fff;text-transform:uppercase;line-height:1.0;"><%= noticia.title %></h1>
    </div>
  </div>
</div>

<!-- Article -->
<article style="padding:60px 24px 80px;background:#fff;">
  <div style="max-width:800px;margin:0 auto;">

    <!-- Byline -->
    <div style="display:flex;align-items:center;gap:14px;padding-bottom:28px;margin-bottom:32px;border-bottom:1px solid #E4E4E7;">
      <img src="/images/Logo.1268415243901683eac4.png" alt="SLVC"
           style="width:40px;height:40px;object-fit:contain;border-radius:8px;background:#F4F4F5;padding:4px;" />
      <div>
        <div class="font-nexa-bold" style="font-size:13px;color:#0A0A0A;">San Lorenzo de Villa Castells</div>
        <div class="font-nexa" style="font-size:11px;color:#A1A1AA;text-transform:uppercase;letter-spacing:0.06em;margin-top:2px;">
          <%= new Date(noticia.date).toLocaleDateString('es-AR',{weekday:'long',day:'2-digit',month:'long',year:'numeric'}) %>
        </div>
      </div>
      <!-- Share mini -->
      <div style="margin-left:auto;display:flex;gap:8px;">
        <a href="https://www.instagram.com/slvc.oficial/" target="_blank"
           style="width:34px;height:34px;border:1.5px solid #E4E4E7;border-radius:8px;display:flex;align-items:center;justify-content:center;color:#71717A;transition:all 0.2s;"
           onmouseover="this.style.borderColor='#8B0000';this.style.color='#8B0000'" onmouseout="this.style.borderColor='#E4E4E7';this.style.color='#71717A'">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2zm0 1.5A4.25 4.25 0 0 0 3.5 7.75v8.5A4.25 4.25 0 0 0 7.75 20.5h8.5A4.25 4.25 0 0 0 20.5 16.25v-8.5A4.25 4.25 0 0 0 16.25 3.5zm4.25 3a5.5 5.5 0 1 1 0 11 5.5 5.5 0 0 1 0-11zm0 1.5a4 4 0 1 0 0 8 4 4 0 0 0 0-8zm5.25-.75a.875.875 0 1 1 0 1.75.875.875 0 0 1 0-1.75z"/></svg>
        </a>
      </div>
    </div>

    <!-- Subtitle -->
    <p class="font-nexa-bold" style="font-size:18px;color:#3f3f46;line-height:1.6;margin-bottom:28px;"><%= noticia.subtitle %></p>

    <!-- Body -->
    <div class="article-body">
      <%- noticia.content %>
    </div>

    <!-- Gallery -->
    <% if(noticia.gallery && noticia.gallery.length > 1){ %>
    <div style="margin-top:48px;">
      <div class="section-label" style="margin-bottom:16px;">Galería de fotos</div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:8px;">
        <% noticia.gallery.forEach(function(img){ %>
        <div style="border-radius:8px;overflow:hidden;aspect-ratio:1;cursor:pointer;"
             onclick="openLightbox('<%= img %>')">
          <img src="<%= img %>" alt=""
               style="width:100%;height:100%;object-fit:cover;transition:transform 0.4s;"
               onmouseover="this.style.transform='scale(1.06)'" onmouseout="this.style.transform='scale(1)'" />
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- Nav prev/next -->
    <div style="margin-top:56px;padding-top:32px;border-top:1px solid #E4E4E7;display:grid;grid-template-columns:1fr 1fr;gap:16px;">
      <% if(prev){ %>
      <a href="/noticias/<%= prev.slug %>" class="card" style="text-decoration:none;padding:16px;display:flex;align-items:center;gap:12px;border-radius:12px;">
        <div style="width:48px;height:48px;border-radius:8px;overflow:hidden;flex-shrink:0;">
          <img src="<%= prev.thumbnail || prev.image %>" style="width:100%;height:100%;object-fit:cover;" />
        </div>
        <div>
          <div class="font-nexa" style="font-size:10px;color:#A1A1AA;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:2px;">← Anterior</div>
          <div class="font-nexa-bold" style="font-size:13px;color:#0A0A0A;line-height:1.2;"><%= prev.title %></div>
        </div>
      </a>
      <% } else { %><div></div><% } %>

      <% if(next){ %>
      <a href="/noticias/<%= next.slug %>" class="card" style="text-decoration:none;padding:16px;display:flex;align-items:center;gap:12px;justify-content:flex-end;text-align:right;border-radius:12px;">
        <div>
          <div class="font-nexa" style="font-size:10px;color:#A1A1AA;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:2px;">Siguiente →</div>
          <div class="font-nexa-bold" style="font-size:13px;color:#0A0A0A;line-height:1.2;"><%= next.title %></div>
        </div>
        <div style="width:48px;height:48px;border-radius:8px;overflow:hidden;flex-shrink:0;">
          <img src="<%= next.thumbnail || next.image %>" style="width:100%;height:100%;object-fit:cover;" />
        </div>
      </a>
      <% } else { %><div></div><% } %>
    </div>
  </div>
</article>

<!-- Lightbox -->
<div id="lightbox" onclick="closeLightbox()"
     style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,0.92);align-items:center;justify-content:center;cursor:pointer;">
  <img id="lb-img" style="max-width:90vw;max-height:88vh;object-fit:contain;border-radius:4px;" />
</div>
<script>
function openLightbox(src){
  const lb=document.getElementById('lightbox');
  document.getElementById('lb-img').src=src;
  lb.style.display='flex';
}
function closeLightbox(){
  document.getElementById('lightbox').style.display='none';
}
</script>

<%- include('partials/footer') %>
</body>
</html>
